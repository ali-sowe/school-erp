@baseUrl = http://localhost:5000/api

### login as the seeded Platform Administrator
# (bootstrapped by seedPlatformAdministrator() on first server boot)
POST {{baseUrl}}/auth/login HTTP/1.1
Content-Type: application/json

{
    "email": "admin@schoolerp.com",
    "password": "Admin@123"
}

### ME (uses the httpOnly cookie set by login above — no header needed)
GET {{baseUrl}}/auth/me HTTP/1.1

### logout
POST {{baseUrl}}/auth/logout HTTP/1.1

###############################################
# Onboarding a new school (Platform Administrator only)
# Creates the school + its default roles (Administrator/Teacher/Student/Parent)
# + its first Administrator user, atomically.
###############################################

### create a school
POST {{baseUrl}}/schools HTTP/1.1
Content-Type: application/json

{
    "name": "Nusrat Senior Secondary School",
    "ownership_type": "private",
    "region": "Kanifing",
    "education_levels": ["LOWER_BASIC", "UPPER_BASIC", "SENIOR_SECONDARY"],
    "admin": {
        "first_name": "Fatou",
        "last_name": "Jallow",
        "email": "admin@nusrat.edu.gm",
        "password": "Admin@123"
    }
}

### get all schools (Platform Administrator only)
GET {{baseUrl}}/schools HTTP/1.1

### get school by id
GET {{baseUrl}}/schools/1 HTTP/1.1

### update school
PATCH {{baseUrl}}/schools/1 HTTP/1.1
Content-Type: application/json

{
    "region": "Greater Banjul"
}

### suspend school
PATCH {{baseUrl}}/schools/1/suspend HTTP/1.1

### reactivate school
PATCH {{baseUrl}}/schools/1/reactivate HTTP/1.1

###############################################
# From here on, log in as the school's own Administrator
# (the one created during onboarding above) — every request below is
# automatically scoped to that school via the JWT's schoolId claim.
###############################################

### login as the school Administrator
POST {{baseUrl}}/auth/login HTTP/1.1
Content-Type: application/json

{
    "email": "admin@nusrat.edu.gm",
    "password": "Admin@123"
}

### create academic year
POST {{baseUrl}}/academic-years HTTP/1.1
Content-Type: application/json

{
    "name": "2028/2029",
    "start_date": "2028-09-01",
    "end_date": "2029-06-30"
}

### get all academic years (scoped to the logged-in school automatically)
GET {{baseUrl}}/academic-years HTTP/1.1

### get academic year by id
GET {{baseUrl}}/academic-years/1 HTTP/1.1

### update academic year
PATCH {{baseUrl}}/academic-years/1 HTTP/1.1
Content-Type: application/json

{
    "name": "2026/2027",
    "start_date": "2026-09-02",
    "end_date": "2027-06-30"
}

### activate academic year
PATCH {{baseUrl}}/academic-years/1/activate HTTP/1.1

### complete academic year
PATCH {{baseUrl}}/academic-years/1/complete HTTP/1.1

### override academic year (authorized exception — see Calendar Engine doc)
PATCH {{baseUrl}}/academic-years/1/override HTTP/1.1
Content-Type: application/json

{
    "actual_start_date": "2028-09-10",
    "reason": "Reopening delayed one week due to national holiday adjustment"
}

### create term
POST {{baseUrl}}/terms HTTP/1.1
Content-Type: application/json

{
    "academic_year_id": 1,
    "name": "Term 1",
    "start_date": "2028-09-01",
    "end_date": "2028-12-15"
}

### get all terms (scoped to the logged-in school)
GET {{baseUrl}}/terms HTTP/1.1

### get terms for a specific academic year
GET {{baseUrl}}/terms?academic_year_id=1 HTTP/1.1

### get term by id
GET {{baseUrl}}/terms/1 HTTP/1.1

### update term
PATCH {{baseUrl}}/terms/1 HTTP/1.1
Content-Type: application/json

{
    "name": "First Term"
}

### activate term
PATCH {{baseUrl}}/terms/1/activate HTTP/1.1

### complete term
PATCH {{baseUrl}}/terms/1/complete HTTP/1.1

###############################################
# Classes, Grades & Subjects
# School-level structural data (NOT tied to an academic year — a grade level,
# class, or subject is a standing part of the school's structure).
###############################################

### create a grade level
# education_level must be one of the values the school configured at
# onboarding (see education_levels above) — e.g. UPPER_BASIC.
POST {{baseUrl}}/grade-levels HTTP/1.1
Content-Type: application/json

{
    "name": "Grade 7",
    "education_level": "UPPER_BASIC",
    "sequence_order": 7
}

### get all grade levels (scoped to the logged-in school)
GET {{baseUrl}}/grade-levels HTTP/1.1

### get only active grade levels
GET {{baseUrl}}/grade-levels?status=ACTIVE HTTP/1.1

### get grade level by id
GET {{baseUrl}}/grade-levels/1 HTTP/1.1

### update grade level
PATCH {{baseUrl}}/grade-levels/1 HTTP/1.1
Content-Type: application/json

{
    "sequence_order": 7
}

### archive grade level
PATCH {{baseUrl}}/grade-levels/1/archive HTTP/1.1

### restore grade level
PATCH {{baseUrl}}/grade-levels/1/restore HTTP/1.1

### create a subject
POST {{baseUrl}}/subjects HTTP/1.1
Content-Type: application/json

{
    "name": "Mathematics",
    "code": "MATH",
    "is_core": true
}

### get all subjects (scoped to the logged-in school)
GET {{baseUrl}}/subjects HTTP/1.1

### get subject by id
GET {{baseUrl}}/subjects/1 HTTP/1.1

### update subject
PATCH {{baseUrl}}/subjects/1 HTTP/1.1
Content-Type: application/json

{
    "name": "Mathematics I"
}

### archive subject
PATCH {{baseUrl}}/subjects/1/archive HTTP/1.1

### restore subject
PATCH {{baseUrl}}/subjects/1/restore HTTP/1.1

### create a class under a grade level
POST {{baseUrl}}/classes HTTP/1.1
Content-Type: application/json

{
    "grade_level_id": 1,
    "name": "A",
    "capacity": 35
}

### get all classes (scoped to the logged-in school)
GET {{baseUrl}}/classes HTTP/1.1

### get classes for a specific grade level
GET {{baseUrl}}/classes?grade_level_id=1 HTTP/1.1

### get class by id
GET {{baseUrl}}/classes/1 HTTP/1.1

### update class
PATCH {{baseUrl}}/classes/1 HTTP/1.1
Content-Type: application/json

{
    "capacity": 40
}

### archive class
PATCH {{baseUrl}}/classes/1/archive HTTP/1.1

### restore class
PATCH {{baseUrl}}/classes/1/restore HTTP/1.1

### assign a subject to a class
POST {{baseUrl}}/classes/1/subjects HTTP/1.1
Content-Type: application/json

{
    "subject_id": 1
}

### get subjects assigned to a class
GET {{baseUrl}}/classes/1/subjects HTTP/1.1

### remove a subject from a class
DELETE {{baseUrl}}/classes/1/subjects/1 HTTP/1.1

### create a student (admission_number auto-generated if omitted)
POST {{baseUrl}}/students HTTP/1.1
Content-Type: application/json

{
    "first_name": "Amie",
    "last_name": "Jallow",
    "gender": "Female",
    "date_of_birth": "2014-03-12"
}

### get all students (scoped to the logged-in school)
GET {{baseUrl}}/students HTTP/1.1

### search students by name or admission number
GET {{baseUrl}}/students?search=Amie HTTP/1.1

### get student by id
GET {{baseUrl}}/students/1 HTTP/1.1

### update student
PATCH {{baseUrl}}/students/1 HTTP/1.1
Content-Type: application/json

{
    "gender": "Female"
}

### archive student
PATCH {{baseUrl}}/students/1/archive HTTP/1.1

### restore student
PATCH {{baseUrl}}/students/1/restore HTTP/1.1

### create a guardian
POST {{baseUrl}}/guardians HTTP/1.1
Content-Type: application/json

{
    "first_name": "Lamin",
    "last_name": "Jallow",
    "phone": "+2203456789",
    "occupation": "Trader"
}

### get all guardians (scoped to the logged-in school)
GET {{baseUrl}}/guardians HTTP/1.1

### search guardians by phone/email/name (helps avoid registering a duplicate for a sibling)
GET {{baseUrl}}/guardians?search=+2203456789 HTTP/1.1

### get guardian by id
GET {{baseUrl}}/guardians/1 HTTP/1.1

### update guardian
PATCH {{baseUrl}}/guardians/1 HTTP/1.1
Content-Type: application/json

{
    "phone": "+2207654321"
}

### archive guardian
PATCH {{baseUrl}}/guardians/1/archive HTTP/1.1

### restore guardian
PATCH {{baseUrl}}/guardians/1/restore HTTP/1.1

### link a guardian to a student
POST {{baseUrl}}/students/1/guardians HTTP/1.1
Content-Type: application/json

{
    "guardian_id": 1,
    "relationship": "Father",
    "is_primary_contact": true
}

### get guardians linked to a student
GET {{baseUrl}}/students/1/guardians HTTP/1.1

### get students linked to a guardian (reverse lookup, e.g. siblings)
GET {{baseUrl}}/guardians/1/students HTTP/1.1

### unlink a guardian from a student
DELETE {{baseUrl}}/students/1/guardians/1 HTTP/1.1

### enroll a student into a class (academic_year_id defaults to the active year if omitted)
POST {{baseUrl}}/students/1/enrollments HTTP/1.1
Content-Type: application/json

{
    "class_id": 1
}

### get a student's full enrollment history (across academic years)
GET {{baseUrl}}/students/1/enrollments HTTP/1.1

### transfer a student to a different class within the same academic year
PATCH {{baseUrl}}/students/1/enrollments/1/transfer HTTP/1.1
Content-Type: application/json

{
    "class_id": 2
}

### withdraw a student's enrollment
PATCH {{baseUrl}}/students/1/enrollments/1/withdraw HTTP/1.1
Content-Type: application/json

{
    "reason": "Family relocated"
}

### mark an academic year's enrollment as completed (end of year)
PATCH {{baseUrl}}/students/1/enrollments/1/complete HTTP/1.1

### get a class roster (academic_year_id defaults to the active year if omitted)
GET {{baseUrl}}/classes/1/roster HTTP/1.1
